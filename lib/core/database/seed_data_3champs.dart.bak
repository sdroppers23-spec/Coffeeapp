      225: 'Колумбія Decaf 1 фільтр',
      226: 'Колумбія Decaf 2 фільтр',
    };

    final enNames = {
      101: 'Ethiopia 37 Espresso - Uraga',
      102: 'Colombia 46 Espresso',
      103: 'Rwanda 14 Espresso',
      104: 'Colombia 45 Espresso',
      105: 'Kenya 20 Espresso',
      106: 'Rwanda 4 Espresso',
      107: 'Rwanda 13 Espresso',
      108: 'Guatemala 9 Espresso',
      109: 'El Salvador 15 Espresso',
      110: 'Ethiopia 12 Espresso',
      111: 'Uganda 2 Espresso',
      112: 'Honduras 13 Espresso',
      113: 'El Salvador 14 Espresso',
      114: 'Ethiopia 28 Espresso',
      115: 'Colombia 37 Espresso',
      116: 'Colombia 34 Espresso',
      117: 'Honduras 17 Espresso',
      118: 'Guatemala 12 Espresso',
      119: 'Colombia Decaf 1 Espresso',
      120: 'Colombia Decaf 2 Espresso',
      201: 'Colombia 50 Filter - Monteverde',
      202: 'Colombia 49 Filter - Acevedo',
      203: 'Colombia 48 Filter - La Roca',
      204: 'Colombia 47 Filter',
      205: 'Colombia 46 Filter',
      206: 'Colombia 31 Filter',
      207: 'Colombia 45 Filter',
      208: 'Kenya 20 Filter',
      209: 'Ethiopia 37 Filter - Uraga',
      210: 'Indonesia 4 Filter',
      211: 'Rwanda 4 Filter',
      212: 'Rwanda 14 Filter',
      213: 'Rwanda 13 Filter',
      214: 'Colombia 9 Filter',
      215: 'Costa Rica 12 Filter',
      216: 'Indonesia 5 Filter',
      217: 'Ethiopia 8 Filter',
      218: 'Ethiopia 28 Filter',
      219: 'Colombia 37 Filter',
      220: 'Kenya 10 Filter',
      221: 'Colombia 44 Filter',
      222: 'Costa Rica 9 Filter',
      223: 'BB2 Brew Blend 2',
      224: 'Colombia 4 Filter',
      225: 'Colombia Decaf 1 Filter',
      226: 'Colombia Decaf 2 Filter',
    };

    final flavorNotesUK = {
      101: 'Персик, жасмин, яблуко',
      201: 'Вишня, Сицилійський апельсин, Ревінь',
      202: 'Жасмин, бузина, алича',
      203: 'Шовковиця, нектарин, фруктовий льодяник',
      204: 'Іскриста яблучна кава, ківі, какао',
      205: 'Груша, марципан, ягідний післясмак',
      206: 'Жасмин, ківі, лохина',
    };

    final flavorsUK = {
      'fruity': jsonEncode(['Тропічні фрукти', 'Цитрусові', 'Ягоди']),
      'chocolate': jsonEncode(['Шоколад', 'Горіхи', 'Карамель']),
      'floral': jsonEncode(['Квіти', 'Мед', 'Персик']),
    };

    for (final id in ukNames.keys) {
      final isEspresso = id < 200;
      final fType =
          id % 3 == 0 ? 'fruity' : (id % 2 == 0 ? 'chocolate' : 'floral');

      final lotName = ukNames[id] ?? '';
      final nameParts = lotName.split(' - ');
      final regionUK =
          nameParts.length > 1 ? nameParts.last : lotName.split(' ').first;

      final lotCode = lotCodes[id] ?? '';
      final varietyUK = varietyMapping[lotCode] ?? 'Mixed Heirloom / Caturra';
      final descriptionUK = descriptionMapping[lotCode] ??
          'Преміальний лот від 3 Champs Roastery. Ретельно відібране зерно з високим потенціалом солодкості та балансу.';

      list.add(LocalizedBeanTranslationsCompanion.insert(
        beanId: id,
        languageCode: 'uk',
        country: Value(lotName.split(' ').first),
        region: Value(regionUK),
        varieties: Value(varietyUK),
        flavorNotes: Value(flavorNotesUK[id] ?? flavorsUK[fType]!),
        processMethod: Value(id % 2 == 0 ? 'Washed' : 'Natural'),
        description: Value(descriptionUK),
        roastLevel: Value(isEspresso ? 'Medium' : 'Light'),
      ));

      list.add(LocalizedBeanTranslationsCompanion.insert(
        beanId: id,
        languageCode: 'en',
        country: Value(enNames[id]!.split(' ').first),
        region: Value(regionUK),
        varieties: Value(varietyUK),
        flavorNotes: Value(jsonEncode(['Fruits', 'Nuts', 'Sweetness'])),
        processMethod: Value(id % 2 == 0 ? 'Washed' : 'Natural'),
        description: Value(descriptionUK),
        roastLevel: Value(isEspresso ? 'Medium' : 'Light'),
      ));
    }
    return list;
  }

  static Insertable<LocalizedBean> _b(
      int id,
      String emoji,
      int altMin,
      int altMax,
      String lot,
      String sca,
      String sensory,
      String price,
      bool isPrem) {
    return LocalizedBeansCompanion.insert(
      id: Value(id),
      brandId: Value(brandId),
      countryEmoji: Value(emoji),
      altitudeMin: Value(altMin),
      altitudeMax: Value(altMax),
      lotNumber: Value(lot),
      scaScore: Value(sca),
      sensoryJson: Value(sensory),
      priceJson: Value(price),
      isPremium: Value(isPrem),
    );
  }
}
